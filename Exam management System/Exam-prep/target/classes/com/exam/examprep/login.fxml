<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.exam.examprep.controller.LoginController">
    <children>
        <Label layoutX="173.0" layoutY="24.0" style="-fx-background-radius: 22;" text="Welcome to ExamPrep" textFill="#586159">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <Label layoutX="246.0" layoutY="65.0" text=" Login Here" textFill="#0d1abf">
            <font>
                <Font size="18.0" />
            </font>
        </Label>
        <Label layoutX="180.0" layoutY="111.0" text="Email" />
        <TextField fx:id="emailField" layoutX="181.0" layoutY="141.0" prefHeight="26.0" prefWidth="246.0" />
        <Label layoutX="180.0" layoutY="183.0" text="Password" />
        <Button layoutX="262.0" layoutY="257.0" mnemonicParsing="false" onAction="#enterButton" text="Enter" />
        <Label layoutX="209.0" layoutY="299.0" text="You don't have any account?" />
        <Label layoutX="248.0" layoutY="317.0" onMouseClicked="#goToRegistration" text="Register Here" textFill="#c9300a" underline="true" />
        <PasswordField fx:id="passwordField" layoutX="181.0" layoutY="220.0" prefHeight="26.0" prefWidth="246.0" />
        <Label layoutX="32.0" layoutY="359.0" onMouseClicked="#goToQuestionSet" text="For Question set" textFill="#1c16dd" underline="true" />
    </children>
</AnchorPane>
